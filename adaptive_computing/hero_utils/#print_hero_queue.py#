def print_hero_queue():
# Print the state of the queue
        ready_task_records = task_engine.read_tasks(queue_id=queue_record['id'], metatype='Task', state='ready')
        running_task_records = task_engine.read_tasks(queue_id=queue_record['id'], metatype='Task', state='running')
        done_task_records = task_engine.read_tasks(queue_id=queue_record['id'], metatype='Task', state='done')
        #print(f'There are {len(ready_task_records)} tasks in the "ready" state.')
        queued_kestrel = np.array([task['metadata']['slurm_job_id']['kestrel'] for task in ready_task_records]) != -1
        queued_vermillion = np.array([task['metadata']['slurm_job_id']['vermillion'] for task in ready_task_records]) != -1
        not_queued = np.sum(np.logical_and(np.logical_not(queued_kestrel), np.logical_not(queued_vermillion)))
        k_only = np.sum(np.logical_and(queued_kestrel, np.logical_not(queued_vermillion)))
        v_only = np.sum(np.logical_and(np.logical_not(queued_kestrel), queued_vermillion))
        both = np.sum(np.logical_and(queued_kestrel, queued_vermillion))
        print(f'There are {len(ready_task_records)} tasks in the "ready" state. {not_queued} not queued, {k_only} queued on kestrel only, {v_only} queued on vermillion only, {both} queued on both.')
        running_kestrel = np.array([task['metadata']['running']['kestrel'] for task in running_task_records]) == True
        running_vermillion = np.array([task['metadata']['running']['vermillion'] for task in running_task_records]) == True
        k_only = np.sum(np.logical_and(running_kestrel, np.logical_not(running_vermillion)))
        v_only = np.sum(np.logical_and(np.logical_not(running_kestrel), running_vermillion))
        both = np.sum(np.logical_and(running_kestrel, running_vermillion))
        print(f'There are {len(running_task_records)} tasks in the "running" state. {k_only} running on kestrel, {v_only} running on vermillion, {both} running on both')
        if both > 0:
            print(f"WARNING!!!!: {both} tasks are running on both machines.")
        print(f'There are {len(done_task_records)} tasks in the "done" state.')
        queued_kestrel = np.array([task['metadata']['slurm_job_id']['kestrel'] for task in done_task_records]) != -1
        queued_vermillion = np.array([task['metadata']['slurm_job_id']['vermillion'] for task in done_task_records]) != -1
        done_queued_tasks = np.sum(np.logical_or(queued_kestrel, queued_vermillion))
        if done_queued_tasks > 0:
            for task in done_task_records:
                print(f"metadata: {task['metadata']}")
            print(f"WARNING!!!!: {done_queued_tasks} tasks are done but still queued on another machine.")
    
if __name__ == "__main__":
    print_hero_queue():
